			<element xmi:idref="EAID_B38105DF_7400_4d2b_BC21_D2906AB4BAFF" xmi:type="uml:Class" name="observation" scope="public">
				<model package="EAPK_1ACEFA57_4ABB_4d99_90F3_D1320B5B2970" tpos="0" ea_localid="3" ea_eleType="element"/>
				<properties documentation="observation (or observingCapability) wraps one or several deployments used to generate time series of observations of the same observed variable and the same observedGeometryType. Observed variables can be simple or more complex. Cf. 1-01 observedVariable, 1-01 observedGeometryType for more detail." isSpecification="false" sType="Class" nType="0" scope="public" isRoot="false" isLeaf="false" isAbstract="false" isActive="false"/>
				<project author="jkl" version="1.0" phase="1.0" created="2026-03-06 10:35:24" modified="2026-04-02 15:48:47" complexity="1" status="Proposed"/>
				<code product_name="&lt;none&gt;" gentype="&lt;none&gt;"/>
				<style appearance="BackColor=-1;BorderColor=-1;BorderWidth=-1;FontColor=-1;VSwimLanes=1;HSwimLanes=1;BorderStyle=0;"/>
				<tags/>
				<xrefs/>
				<extendedProperties tagged="0" package_name="WMDR2-core"/>
				<attributes>
					<attribute xmi:idref="EAID_52B56F5B_4E28_43ca_9D56_0493B7E2A4EF" name="1-01 observedDomain" scope="Private">
						<initial/>
						<documentation value="cf. http://codes.wmo.int/wmdr/Domain"/>
						<model ea_localid="79" ea_guid="{52B56F5B-4E28-43ca-9D56-0493B7E2A4EF}"/>
						<properties collection="false" static="0" duplicates="0" changeability="changeable"/>
						<coords ordered="0"/>
						<containment containment="Not Specified" position="8"/>
						<stereotype/>
