			<element xmi:idref="EAID_5C6B8DD7_2A53_4d06_8CA0_F0705C236023" xmi:type="uml:Class" name="deployment" scope="public">
				<model package="EAPK_1ACEFA57_4ABB_4d99_90F3_D1320B5B2970" tpos="0" ea_localid="8" ea_eleType="element"/>
				<properties documentation="&quot;deployment&quot; (or &quot;Deployment&quot;) refers to the act of placing an instrument (or human observer) at a location to collect measurements or take samples to be analyzed. In many cases, an instrument (or sensor package) can serve different observations.&#xA;&#xA;Deployments can exist in parallel or in series, one after the other.&#xA;&#xA;The intent is to create a new deployment whenever the observingMethod changes over time.&#xA;&#xA;The same deployment may be used if observations are made with the same brand/model of instrument, even if the specific instrument is rotated in and out, for example as part of operational maintenance cycles in a network." isSpecification="false" sType="Class" nType="0" scope="public" isRoot="false" isLeaf="false" isAbstract="false" isActive="false"/>
				<project author="jkl" version="1.0" phase="1.0" created="2026-03-06 18:34:22" modified="2026-03-18 15:32:35" complexity="1" status="Proposed"/>
				<code product_name="&lt;none&gt;" gentype="&lt;none&gt;"/>
