					</attribute>
					<attribute xmi:idref="EAID_D24AB4F4_84C6_4c70_9217_4FB30D80A11C" name="1-01 observedVariable" scope="Private">
						<initial/>
						<documentation value="The observedVariable is constructed following I-ADOPT ontology approaches, with elements described in a unified vocabulary hosted at codes.wmo.int/wmdr2.&#xA;NB: observedVariable will be a LONG list of entries, each record comprised of notation, name, description. The notation is a unique identifier, not necessarily human-readable. The name is potentially human-readable. The description is a fully fledged definition, human-readable and describing all relevant aspects of an observed variable. It is derived from the observedProperty, the object of interest, the matrix and domain, as well as constraints. Matrix and constraints are defined in controlled vocabularies that may be domain-specific.&#xA;Examples include:&#xA;- observableProperty:  state variable (e.g., temperature, pressure, leaf-area-index (LAI), ...), or another property (e.g., thickness, concentration, scattering coefficient, color, ...)&#xA;- objectOfInterest: sea ice, CO2, aerosol particles, chlorophyll&#xA;- observablePropertyConstraints: a conventional level above ground (e.g., 2m above ground for temperature measurements), a size fraction (e.g., PM2.5), a specific wavelength (e.g., 635 nm), a pressure (range), a temperature (range), a humidity (range), etc., as relevant for the result of the observation. Constraints shall be documented as name-value pairs, where the names shall come from a code list, and the values shall come from a code list depending on the name, or be free text. &#xA;- matrix: atmosphere, interstitial air in the root space, air in an ice core, sea surface, soil, dry air, ...&#xA;&#xA;These elements will be supported by code lists from codes.wmo.int/wmdr2.&#xA;&#xA;Applications may want to guide users to select a specific observedVariable by offering groupings, filtering, or tree-like visualizations according to matrix, objectOfInterest, etc."/>
						<model ea_localid="3" ea_guid="{D24AB4F4-84C6-4c70-9217-4FB30D80A11C}"/>
						<properties derived="0" precision="0" collection="false" length="0" static="0" duplicates="0" changeability="changeable"/>
						<coords ordered="0" scale="0"/>
						<containment containment="Not Specified" position="0"/>
						<stereotype/>
						<bounds lower="1" upper="1"/>
						<options/>
						<style/>
						<styleex value="volatile=0;"/>
						<tags/>
						<xrefs/>
					</attribute>
					<attribute xmi:idref="EAID_50AA3740_6A90_4e3c_9322_AEB4A6E8C4D4" name="1-03 temporalExtent" scope="Private">
						<initial/>
						<documentation value="aggregate derived from deployments if deployments are provided; otherwise, specify begin-end"/>
						<model ea_localid="12" ea_guid="{50AA3740-6A90-4e3c-9322-AEB4A6E8C4D4}"/>
