			<element xmi:idref="EAID_D5A2A12F_D397_4eea_AC75_E35A7C9EB2F6" xmi:type="uml:Class" name="domain" scope="public">
				<model package="EAPK_1ACEFA57_4ABB_4d99_90F3_D1320B5B2970" tpos="0" ea_localid="69" ea_eleType="element"/>
				<properties documentation="Describes the physical domain, i.e. larger-scale environmental target or ultimate-feature-of-interest, of an observation." isSpecification="false" sType="Class" nType="0" scope="public" isRoot="false" isLeaf="false" isAbstract="false" isActive="false"/>
				<project author="jkl" version="1.0" phase="1.0" created="2026-06-10 17:43:57" modified="2026-06-18 11:08:44" complexity="1" status="Proposed"/>
				<code product_name="Java" gentype="Java"/>
				<style appearance="BackColor=-1;BorderColor=-1;BorderWidth=-1;FontColor=-1;VSwimLanes=1;HSwimLanes=1;BorderStyle=0;"/>
				<tags/>
				<xrefs/>
