			<diagram xmi:id="EAID_1C264E1A_10CD_4b0e_9565_9890D5B54547">
				<model package="EAPK_1ACEFA57_4ABB_4d99_90F3_D1320B5B2970" localID="1" owner="EAPK_1ACEFA57_4ABB_4d99_90F3_D1320B5B2970" />
				<properties name="WMDR2-core" type="Logical" documentation="WMDR2core&#10;Notes&#10;1. temporalExtent shall be realized as time:interval&#10;2. temporal&amp;lt;Name&amp;gt; elements other than temporalExtent shall be realized as a dictionary object of two arrays, one for times, one for the values of &amp;lt;Name&amp;gt;, e.g., temporalTerritory = {&#10;&quot;interval&quot;: [2000-01-01, 2024-07-13], &#10;&quot;territory&quot;: [&amp;lt;ISO1&amp;gt;&quot;, &quot;&amp;lt;ISO2&amp;gt;&quot;]&#10;}.&#10;3. Following the OGC Features model, geometry = geolocation = coordinates + elevation&#10;&#10;v0.1.4 Introduce instrument class.&#10;v0.1.5 Expand instrument class." />
				<project author="jkl" version="0.1.6" created="2026-03-06 10:35:24" modified="2026-05-26 18:12:30" />
