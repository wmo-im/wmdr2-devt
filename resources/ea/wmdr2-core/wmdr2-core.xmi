				<attributes>
					<attribute xmi:idref="EAID_39BD91F5_C0D7_4b03_96E6_E955F3489D09" name="domainFeature" scope="Private">
						<initial/>
						<documentation value="Describes the type of the larger-scale environmental target or ultimate-feature-of-interest, of an observation.&#xA;&#xA;Concept motivated by requirements from hydrology, but may be useful elsewhere. New code list is proposed, with terms like&#xA;- river basin&#xA;- lake&#xA;- river&#xA;- catchment&#xA;&#xA;- canopy&#xA;&#xA;- epilimnion&#xA;- hypolimnion&#xA;&#xA;- troposphere&#xA;- tropopause&#xA;- stratosphere&#xA;&#xA;- thermocline (useful as a general term, but needs &quot;domain&quot;)&#xA;- boundary layer (useful as a general term, but needs &quot;domain&quot;)&#xA;&#xA;- ...&#xA;"/>
						<model ea_localid="351" ea_guid="{39BD91F5-C0D7-4b03-96E6-E955F3489D09}"/>
						<properties collection="false" static="0" duplicates="0" changeability="changeable"/>
						<coords ordered="0"/>
						<containment containment="Not Specified" position="1"/>
						<stereotype/>
						<bounds lower="0" upper="1"/>
						<options/>
						<style/>
						<styleex value="volatile=0;"/>
						<tags/>
						<xrefs/>
					</attribute>
					<attribute xmi:idref="EAID_1DBC14A4_4A9A_4f7a_8C82_FA151372F959" name="domainName" scope="Private">
						<initial/>
						<documentation value="The largest scale in WIGOS, cf. http://codes.wmo.int/wmdr/Domain&#xA;"/>
						<model ea_localid="350" ea_guid="{1DBC14A4-4A9A-4f7a-8C82-FA151372F959}"/>
