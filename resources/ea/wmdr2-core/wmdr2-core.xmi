					</attribute>
					<attribute xmi:idref="EAID_712F488E_E0D0_4e7d_AB07_A69A6FF2D294" name="1-01 observedGeometryType" scope="Private">
						<initial/>
						<documentation value="cf. http://codes.wmo.int/wmdr/Geometry"/>
						<model ea_localid="9" ea_guid="{712F488E-E0D0-4e7d-AB07-A69A6FF2D294}"/>
						<properties collection="false" static="0" duplicates="0" changeability="changeable"/>
						<coords ordered="0"/>
						<containment containment="Not Specified" position="1"/>
						<stereotype/>
						<bounds lower="1" upper="1"/>
						<options/>
