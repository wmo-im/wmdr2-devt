{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.wmo.int/wmdr/2.0/schemas/wmdr2-feature-collection.schema.json",
  "title": "WMDR2 core FeatureCollection wrapper",
  "description": "Optional non-empty FeatureCollection wrapper around facility-centric WMDR2 record Features.",
  "type": "object",
  "required": ["type", "features"],
  "additionalProperties": true,
  "properties": {
    "type": { "const": "FeatureCollection" },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "wmdr2-record-feature.schema.json" }
    }
  }
}
