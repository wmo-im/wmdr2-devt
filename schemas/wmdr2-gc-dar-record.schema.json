{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wmo.int/wmdr2/schemas/wmdr2-gc-dar-record.schema.json",
  "title": "WMDR2 GC-DAR discovery record",
  "type": "object",
  "required": ["type", "id", "properties"],
  "properties": {
    "type": {"const": "Feature"},
    "id": {"type": "string"},
    "geometry": {"type": ["object", "null"]},
    "time": {"type": "object"},
    "conformsTo": {"type": "array", "items": {"type": "string"}},
    "properties": {
      "type": "object",
      "required": ["profile", "type"],
      "properties": {
        "type": {"const": "facility"},
        "profile": {"const": "wmdr2-gc-dar"},
        "title": {"type": "string"},
        "description": {"type": "string"},
        "keywords": {"type": "array"},
        "territory": {"type": ["string", "integer"]},
        "programAffiliations": {"type": "array"},
        "observedProperty": {"type": "array"},
        "observedFeatureDomain": {"type": "array"},
        "observationSeries": {"type": "array"},
        "provenance": {"type": "object"},
        "retrieval": {"type": "object"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
