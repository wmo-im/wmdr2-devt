{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wmo-im.github.io/wmdr2-devt/schemas/wmdr2-gc-dar-record.schema.json",
  "title": "WMDR2 GC-DAR discovery, access and retrieval record",
  "description": "Derived OGC Records-friendly current-state discovery projection for a WMDR2 v0.2.5 full facility record.",
  "type": "object",
  "required": [
    "type",
    "id",
    "properties"
  ],
  "additionalProperties": true,
  "properties": {
    "type": {
      "const": "Feature"
    },
    "id": {
      "type": "string",
      "pattern": "^facility:"
    },
    "geometry": {
      "anyOf": [
        {
          "type": "object",
          "required": [
            "type",
            "coordinates"
          ],
          "properties": {
            "type": {
              "const": "Point"
            },
            "coordinates": {
              "type": "array",
              "minItems": 2,
              "maxItems": 3,
              "items": {
                "type": "number"
              }
            }
          },
          "additionalProperties": true
        },
        {
          "type": "null"
        }
      ]
    },
    "time": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "interval": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {
                "type": "string"
              }
            }
          },
          "required": [
            "interval"
          ],
          "additionalProperties": true
        },
        {
          "type": "null"
        }
      ]
    },
    "conformsTo": {
      "type": "array",
      "contains": {
        "const": "http://wigos.wmo.int/spec/wmdr/2/conf/gc-dar"
      },
      "items": {
        "type": "string"
      }
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/link"
      }
    },
    "properties": {
      "type": "object",
      "required": [
        "type",
        "profile",
        "modelVersion",
        "sourceProfile",
        "title",
        "provenance"
      ],
      "additionalProperties": true,
      "properties": {
        "type": {
          "const": "facility"
        },
        "profile": {
          "const": "wmdr2-gc-dar"
        },
        "modelVersion": {
          "const": "0.2.5"
        },
        "sourceProfile": {
          "const": "wmdr2-full"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "created": {
          "type": "string"
        },
        "updated": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "contacts": {
          "type": "array"
        },
        "observationSeries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observationSeriesSummary"
          }
        },
        "deployments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "instruments": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "retrieval": {
          "$ref": "#/$defs/retrieval"
        },
        "facilitySets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "territory": {
          "type": "string"
        },
        "wmoRegion": {},
        "facilityType": {},
        "programAffiliation": {
          "$ref": "#/$defs/programAffiliations"
        },
        "observedProperty": {
          "type": "array"
        },
        "observedGeometry": {
          "type": "array"
        },
        "observedFeatureDomain": {
          "type": "array"
        },
        "observedFeatureDomainFeature": {
          "type": "array"
        },
        "observedFeatureName": {
          "type": "array"
        },
        "applicationArea": {
          "type": "array"
        },
        "officialStatus": {
          "type": "array"
        },
        "observationSeriesCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "required": [
        "rel",
        "href"
      ],
      "additionalProperties": true,
      "properties": {
        "rel": {
          "type": "string"
        },
        "href": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "profile": {
          "type": "string"
        }
      }
    },
    "programAffiliations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/programAffiliation"
      }
    },
    "programAffiliation": {
      "type": "object",
      "required": [
        "program",
        "reportingStatus"
      ],
      "additionalProperties": true,
      "properties": {
        "program": {
          "type": "string"
        },
        "reportingStatus": {
          "type": "string"
        },
        "date": {
          "type": "string"
        }
      }
    },
    "observationSeriesSummary": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^observationSeries:"
        },
        "title": {
          "type": "string"
        },
        "time": {
          "type": "object"
        },
        "current": {
          "type": "boolean"
        },
        "observedProperty": {},
        "observedGeometry": {},
        "observedFeature": {
          "type": "object"
        },
        "programAffiliation": {
          "type": "array"
        },
        "applicationArea": {
          "type": "array"
        },
        "sourceOfObservation": {},
        "officialStatus": {},
        "deployment": {
          "type": "string"
        },
        "instrument": {
          "type": "string"
        },
        "observingMethod": {},
        "observingConfigurationDate": {
          "type": "string"
        },
        "uom": {},
        "internationalExchange": {
          "type": "boolean"
        },
        "temporalAggregate": {},
        "levelOfData": {},
        "dataPolicy": {},
        "timeliness": {},
        "reportingDate": {
          "type": "string"
        },
        "reportingStrategy": {}
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "derivedFrom",
        "sourceProfile",
        "sourceContentHash",
        "derivedAt"
      ],
      "additionalProperties": true,
      "properties": {
        "derivedFrom": {
          "type": "string",
          "pattern": "^facility:"
        },
        "sourceProfile": {
          "const": "wmdr2-full"
        },
        "sourceConformsTo": {
          "type": "array"
        },
        "sourceContentHash": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "derivedAt": {
          "type": "string"
        },
        "sourceFile": {
          "type": "string"
        }
      }
    },
    "retrieval": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "fullRecord": {
          "$ref": "#/$defs/retrievalLink"
        },
        "darRecord": {
          "$ref": "#/$defs/retrievalLink"
        }
      }
    },
    "retrievalLink": {
      "type": "object",
      "required": [
        "href",
        "type"
      ],
      "additionalProperties": true,
      "properties": {
        "href": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "profile": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      }
    }
  }
}
