{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wmo-im.github.io/wmdr2-devt/schemas/wmdr2-record-feature.schema.json",
  "title": "WMDR2 facility-centric Feature",
  "type": "object",
  "required": [
    "type",
    "id",
    "properties"
  ],
  "additionalProperties": true,
  "properties": {
    "type": {
      "const": "Feature"
    },
    "id": {
      "type": "string",
      "pattern": "^facility:"
    },
    "geometry": {
      "anyOf": [
        {
          "$ref": "wmdr2-common.schema.json#/$defs/pointGeometry"
        },
        {
          "type": "null"
        }
      ]
    },
    "temporalGeometry": {
      "$ref": "wmdr2-common.schema.json#/$defs/temporalGeometry"
    },
    "time": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "interval": {
              "type": "array",
              "items": {
                "$ref": "wmdr2-common.schema.json#/$defs/dateOrOpen"
              },
              "minItems": 2,
              "maxItems": 2
            }
          },
          "required": [
            "interval"
          ],
          "additionalProperties": true
        },
        {
          "type": "null"
        }
      ]
    },
    "conformsTo": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "const": "http://wigos.wmo.int/spec/wmdr/2/conf/core"
      }
    },
    "properties": {
      "type": "object",
      "required": [
        "type",
        "title"
      ],
      "additionalProperties": true,
      "allOf": [
        {
          "not": {
            "required": [
              "temporalProgramAffiliation"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalTerritory"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalReportingStatus"
            ]
          }
        },
        {
          "not": {
            "required": [
              "externalIds"
            ]
          }
        },
        {
          "not": {
            "required": [
              "facilitySet"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalClimateZone"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalSurfaceCover"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalPopulation"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalSurfaceRoughness"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalGeometry"
            ]
          }
        },
        {
          "not": {
            "required": [
              "observations"
            ]
          }
        },
        {
          "not": {
            "required": [
              "historicalEnvironment"
            ]
          }
        },
        {
          "not": {
            "required": [
              "historicalProgramAffiliation"
            ]
          }
        },
        {
          "not": {
            "required": [
              "historicalTerritory"
            ]
          }
        }
      ],
      "properties": {
        "type": {
          "const": "facility"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "created": {
          "type": "string"
        },
        "updated": {
          "type": "string"
        },
        "contacts": {
          "type": "array",
          "items": {
            "$ref": "wmdr2-common.schema.json#/$defs/contact"
          }
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "wmdr2-common.schema.json#/$defs/link"
          }
        },
        "facilitySets": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^facilitySet:"
          }
        },
        "programAffiliation": {
          "$ref": "wmdr2-common.schema.json#/$defs/programAffiliation"
        },
        "territory": {
          "$ref": "wmdr2-common.schema.json#/$defs/territory"
        },
        "environment": {
          "$ref": "https://wmo-im.github.io/wmdr2-devt/schemas/wmdr2-common.schema.json#/$defs/environment"
        },
        "schedules": {
          "type": "array",
          "items": {
            "$ref": "wmdr2-common.schema.json#/$defs/schedule"
          }
        },
        "observationSeries": {
          "type": "array",
          "items": {
            "$ref": "https://wmo-im.github.io/wmdr2-devt/schemas/wmdr2-common.schema.json#/$defs/observationSeries"
          }
        },
        "instruments": {
          "type": "array",
          "items": {
            "$ref": "wmdr2-common.schema.json#/$defs/instrument"
          }
        },
        "reporting": {
          "type": "array",
          "items": {
            "$ref": "https://wmo-im.github.io/wmdr2-devt/schemas/wmdr2-common.schema.json#/$defs/reporting"
          }
        },
        "deployments": {
          "type": "array",
          "items": {
            "$ref": "https://wmo-im.github.io/wmdr2-devt/schemas/wmdr2-common.schema.json#/$defs/deployment"
          }
        },
        "procedures": {
          "type": "array",
          "items": {
            "$ref": "https://wmo-im.github.io/wmdr2-devt/schemas/wmdr2-common.schema.json#/$defs/procedure"
          }
        }
      }
    }
  }
}
