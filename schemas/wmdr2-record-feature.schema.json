{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.wmo.int/wmdr/2.0/schemas/wmdr2-record-feature.schema.json",
  "title": "WMDR2 core facility-centric record Feature",
  "description": "Facility-centric WMDR2 core JSON representation using a GeoJSON/OGC Records Feature envelope.",
  "type": "object",
  "required": [
    "type",
    "id",
    "geometry",
    "time",
    "conformsTo",
    "properties"
  ],
  "additionalProperties": true,
  "properties": {
    "type": {
      "const": "Feature"
    },
    "id": {
      "type": "string",
      "pattern": "^facility:"
    },
    "geometry": {
      "$ref": "wmdr2-common.schema.json#/$defs/pointGeometry"
    },
    "time": {
      "$ref": "wmdr2-common.schema.json#/$defs/nullableTimeInterval"
    },
    "conformsTo": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "allOf": [
        {
          "contains": {
            "const": "http://www.opengis.net/spec/ogcapi-records-1/1.0/conf/record-core"
          }
        },
        {
          "contains": {
            "const": "https://schemas.wmo.int/wmdr/2.0/core/full-record"
          }
        }
      ]
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "wmdr2-common.schema.json#/$defs/link"
      }
    },
    "properties": {
      "type": "object",
      "required": [
        "type",
        "title"
      ],
      "additionalProperties": true,
      "allOf": [
        {
          "not": {
            "required": [
              "wmdr2"
            ]
          }
        },
        {
          "not": {
            "required": [
              "themes"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalContacts"
            ]
          }
        },
        {
          "not": {
            "required": [
              "dateEstablished"
            ]
          }
        },
        {
          "not": {
            "required": [
              "dateClosed"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalGeometry"
            ]
          }
        },
        {
          "not": {
            "required": [
              "externalIds"
            ]
          }
        },
        {
          "not": {
            "required": [
              "facilitySet"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalClimateZone"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalSurfaceCover"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalPopulation"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalPopulationDensities"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalSurfaceRoughness"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalLocalTopography"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalRelativeElevation"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalTopographicContext"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalAltitudeOrDepth"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalTopographyBathymetry"
            ]
          }
        }
      ],
      "properties": {
        "type": {
          "const": "facility"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "created": {
          "type": "string"
        },
        "updated": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "contacts": {
          "type": "array",
          "items": {
            "$ref": "wmdr2-common.schema.json#/$defs/contact"
          }
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "wmdr2-common.schema.json#/$defs/link"
          }
        },
        "facilitySets": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^facilitySet:"
          }
        },
        "facilityType": {
          "$ref": "wmdr2-common.schema.json#/$defs/codeValue"
        },
        "wmoRegion": {
          "$ref": "wmdr2-common.schema.json#/$defs/codeValue"
        },
        "surfaceCoverClassification": {
          "$ref": "wmdr2-common.schema.json#/$defs/codeValue"
        },
        "timeZone": {},
        "regionOfOrigin": {
          "$ref": "wmdr2-common.schema.json#/$defs/codeValue"
        },
        "temporalTerritory": {
          "$ref": "wmdr2-common.schema.json#/$defs/temporalTerritory"
        },
        "environment": {
          "$ref": "wmdr2-common.schema.json#/$defs/environment"
        },
        "temporalProgramAffiliation": {
          "$ref": "wmdr2-common.schema.json#/$defs/temporalProgramAffiliation"
        },
        "temporalReportingStatus": {
          "$ref": "wmdr2-common.schema.json#/$defs/reportingStatusTimeline"
        },
        "observations": {
          "type": "array",
          "items": {
            "$ref": "wmdr2-common.schema.json#/$defs/observation"
          }
        },
        "deployments": {
          "type": "array",
          "items": {
            "$ref": "wmdr2-common.schema.json#/$defs/deployment"
          }
        },
        "instruments": {
          "type": "array",
          "items": {
            "$ref": "wmdr2-common.schema.json#/$defs/instrument"
          }
        },
        "schedules": {
          "type": "array",
          "items": {
            "$ref": "wmdr2-common.schema.json#/$defs/jscalendarEvent"
          }
        }
      }
    },
    "temporalGeometry": {
      "$ref": "wmdr2-common.schema.json#/$defs/temporalGeometry"
    }
  }
}
