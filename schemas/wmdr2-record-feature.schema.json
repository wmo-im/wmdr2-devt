{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wmo.int/wmdr2/schemas/wmdr2-record-feature.schema.json",
  "title": "WMDR2 v0.3.1 Facility Feature",
  "type": "object",
  "required": [
    "type",
    "id",
    "geometry",
    "properties"
  ],
  "properties": {
    "type": {
      "const": "Feature"
    },
    "id": {
      "type": "string",
      "pattern": "^(wsi|facility|record):"
    },
    "geometry": {
      "$ref": "wmdr2-common.schema.json#/$defs/pointGeometry"
    },
    "temporalGeometry": {
      "$ref": "wmdr2-common.schema.json#/$defs/temporalGeometry"
    },
    "time": {
      "$ref": "wmdr2-common.schema.json#/$defs/time"
    },
    "conformsTo": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "properties": {
      "type": "object",
      "required": [
        "type",
        "title"
      ],
      "properties": {
        "type": {
          "const": "facility"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "created": {
          "type": "string"
        },
        "updated": {
          "type": "string"
        },
        "deployments": false,
        "reporting": false,
        "observationSeries": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "uid",
              "observedProperty",
              "observedFeature",
              "observingConfigurations"
            ],
            "properties": {
              "title": {
                "type": "string"
              },
              "observedProperty": {
                "type": [
                  "integer",
                  "number",
                  "string"
                ]
              },
              "observedFeature": {
                "type": "object",
                "required": [
                  "domain"
                ],
                "properties": {
                  "domain": {
                    "type": [
                      "string",
                      "integer"
                    ]
                  },
                  "domainFeature": {
                    "type": "string"
                  },
                  "featureName": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              },
              "observedGeometry": {
                "type": [
                  "string",
                  "integer",
                  "number"
                ]
              },
              "observingConfigurations": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "wmdr2-common.schema.json#/$defs/observingConfiguration"
                }
              },
              "observingProcedures": {
                "type": "array",
                "items": {
                  "$ref": "wmdr2-common.schema.json#/$defs/observingProcedure"
                }
              },
              "uid": {
                "type": "string",
                "pattern": "^observationSeries:"
              },
              "programAffiliations": {
                "type": "array"
              },
              "reportingProcedures": {
                "type": "array",
                "items": {
                  "$ref": "wmdr2-common.schema.json#/$defs/reportingProcedure"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "environment": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "validFrom"
            ],
            "properties": {
              "validFrom": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "territory": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "validFrom",
              "territory"
            ],
            "properties": {
              "validFrom": {
                "type": "string"
              },
              "territory": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        },
        "schedules": {
          "type": "array",
          "items": {
            "$ref": "wmdr2-common.schema.json#/$defs/schedule"
          }
        },
        "instruments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "uid"
            ],
            "properties": {
              "uid": {
                "type": "string",
                "pattern": "^instrument:"
              }
            },
            "additionalProperties": true
          }
        },
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "uid": {
                "type": "string",
                "pattern": "^contact:"
              },
              "roles": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": true
          }
        },
        "programAffiliations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "validFrom",
              "program"
            ],
            "properties": {
              "validFrom": {
                "type": "string"
              },
              "program": {
                "oneOf": [
                  {
                    "type": [
                      "string",
                      "integer"
                    ]
                  },
                  {
                    "type": "array",
                    "items": {
                      "type": [
                        "string",
                        "integer"
                      ]
                    }
                  }
                ]
              },
              "programSpecificFacilityId": {
                "type": "string"
              },
              "programSpecificFacilityTitle": {
                "type": "string"
              },
              "reportingStatus": {
                "type": [
                  "string",
                  "integer"
                ]
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
