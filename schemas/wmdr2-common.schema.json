{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wmo-im.github.io/wmdr2-devt/schemas/wmdr2-common.schema.json",
  "title": "WMDR2 common schema definitions",
  "type": "object",
  "$defs": {
    "dateOrOpen": {
      "type": "string",
      "description": "ISO date or '..' for open/unknown.",
      "anyOf": [
        {
          "const": ".."
        },
        {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      ]
    },
    "codeValue": {
      "description": "Compact codelist value, URI, number, structured value, or null.",
      "type": [
        "string",
        "number",
        "integer",
        "object",
        "array",
        "boolean",
        "null"
      ]
    },
    "quantity": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "value"
      ],
      "properties": {
        "value": {
          "type": [
            "number",
            "integer",
            "string"
          ]
        },
        "uom": {
          "$ref": "#/$defs/codeValue"
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "href"
      ],
      "properties": {
        "href": {
          "type": "string"
        },
        "rel": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "identifier": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "organization": {
          "type": "string"
        },
        "position": {
          "type": "string"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "emails": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "phones": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "addresses": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        }
      }
    },
    "pointGeometry": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "Point"
        },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "items": {
            "type": "number"
          }
        }
      },
      "additionalProperties": true
    },
    "temporalGeometry": {
      "type": "object",
      "description": "Trajectory-style exception that intentionally uses aligned coordinates/dates arrays.",
      "required": [
        "type",
        "coordinates",
        "dates"
      ],
      "properties": {
        "type": {
          "const": "MovingPoint"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "type": "array"
          }
        },
        "dates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dateOrOpen"
          }
        },
        "methods": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 0,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "additionalProperties": true
    },
    "observedFeature": {
      "type": "object",
      "required": [
        "domain"
      ],
      "additionalProperties": true,
      "properties": {
        "domain": {
          "$ref": "#/$defs/codeValue"
        },
        "domainFeature": {
          "type": [
            "string",
            "object",
            "null"
          ]
        },
        "featureName": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "allOf": [
        {
          "not": {
            "required": [
              "domainName"
            ]
          }
        }
      ]
    },
    "historicalObjectBase": {
      "type": "object",
      "required": [
        "date"
      ],
      "properties": {
        "date": {
          "$ref": "#/$defs/dateOrOpen"
        }
      },
      "additionalProperties": true
    },
    "historicalDeployment": {
      "type": "object",
      "required": [
        "date"
      ],
      "additionalProperties": true,
      "allOf": [
        {
          "$ref": "#/$defs/historicalObjectBase"
        },
        {
          "not": {
            "required": [
              "dates"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalSerialNumber"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalOfficialStatus"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalInstrumentOperatingStatus"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalObservingSchedule"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalGeometry"
            ]
          }
        },
        {
          "not": {
            "required": [
              "observingSchedule"
            ]
          }
        },
        {
          "not": {
            "required": [
              "sourceOfObservation"
            ]
          }
        },
        {
          "not": {
            "required": [
              "referenceSurface"
            ]
          }
        },
        {
          "not": {
            "required": [
              "verticalDistanceFromReferenceSurface"
            ]
          }
        },
        {
          "not": {
            "required": [
              "officialStatus"
            ]
          }
        },
        {
          "not": {
            "required": [
              "serialNumbers"
            ]
          }
        },
        {
          "not": {
            "required": [
              "instrument"
            ]
          }
        },
        {
          "not": {
            "required": [
              "serialNumber"
            ]
          }
        }
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^historicalDeployment:"
        },
        "date": {
          "$ref": "#/$defs/dateOrOpen"
        },
        "operatingStatus": {
          "$ref": "#/$defs/codeValue"
        },
        "exposure": {},
        "geometry": {
          "$ref": "#/$defs/pointGeometry"
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "deployment": {
          "type": "string",
          "pattern": "^deployment:",
          "description": "Reference to the reusable deployment / instrument instance used for this dated observation state."
        }
      }
    },
    "historicalReportingEntry": {
      "type": "object",
      "required": [
        "date"
      ],
      "additionalProperties": true,
      "allOf": [
        {
          "$ref": "#/$defs/historicalObjectBase"
        },
        {
          "not": {
            "required": [
              "internationalExchange"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalReportingInterval"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalAggregate"
            ]
          }
        },
        {
          "not": {
            "required": [
              "aggregation"
            ]
          }
        },
        {
          "not": {
            "required": [
              "dataFormat"
            ]
          }
        },
        {
          "not": {
            "required": [
              "dataPolicy"
            ]
          }
        },
        {
          "not": {
            "required": [
              "levelOfData"
            ]
          }
        },
        {
          "not": {
            "required": [
              "numberOfObservationsInReportingInterval"
            ]
          }
        },
        {
          "not": {
            "required": [
              "referenceDatum"
            ]
          }
        },
        {
          "not": {
            "required": [
              "referenceTimeSource"
            ]
          }
        },
        {
          "not": {
            "required": [
              "timeliness"
            ]
          }
        },
        {
          "not": {
            "required": [
              "timeStampMeaning"
            ]
          }
        }
      ],
      "properties": {
        "date": {
          "$ref": "#/$defs/dateOrOpen"
        },
        "reporting": {
          "type": "string",
          "pattern": "^reporting:"
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "uom": {
          "$ref": "#/$defs/codeValue"
        }
      }
    },
    "historicalReporting": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/historicalReportingEntry"
      }
    },
    "historicalOfficialStatus": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date",
          "officialStatus"
        ],
        "additionalProperties": true,
        "allOf": [
          {
            "$ref": "#/$defs/historicalObjectBase"
          }
        ],
        "properties": {
          "date": {
            "$ref": "#/$defs/dateOrOpen"
          },
          "officialStatus": {
            "$ref": "#/$defs/codeValue"
          }
        }
      }
    },
    "scheduleReference": {
      "type": "object",
      "required": [
        "date",
        "schedule"
      ],
      "additionalProperties": true,
      "properties": {
        "date": {
          "$ref": "#/$defs/dateOrOpen"
        },
        "schedule": {
          "type": "string",
          "pattern": "^schedule_"
        }
      }
    },
    "schedule": {
      "type": "object",
      "required": [
        "@type",
        "uid"
      ],
      "additionalProperties": true,
      "properties": {
        "@type": {
          "type": "string"
        },
        "uid": {
          "type": "string",
          "pattern": "^schedule_"
        },
        "start": {
          "type": "string"
        },
        "timeZone": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "recurrenceRules": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "historicalEnvironment": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date"
        ],
        "additionalProperties": true,
        "allOf": [
          {
            "$ref": "#/$defs/historicalObjectBase"
          },
          {
            "not": {
              "required": [
                "temporalPopulationDensities"
              ]
            }
          },
          {
            "not": {
              "required": [
                "temporalLocalTopography"
              ]
            }
          },
          {
            "not": {
              "required": [
                "temporalRelativeElevation"
              ]
            }
          },
          {
            "not": {
              "required": [
                "temporalTopographicContext"
              ]
            }
          },
          {
            "not": {
              "required": [
                "temporalAltitudeOrDepth"
              ]
            }
          },
          {
            "not": {
              "required": [
                "temporalTopographyBathymetry"
              ]
            }
          },
          {
            "not": {
              "required": [
                "temporalPopulation"
              ]
            }
          },
          {
            "not": {
              "required": [
                "topographyBathymetryTimeline"
              ]
            }
          }
        ],
        "properties": {
          "date": {
            "$ref": "#/$defs/dateOrOpen"
          },
          "climateZone": {},
          "population": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": [
                "number",
                "null"
              ]
            }
          },
          "surfaceCover": {},
          "surfaceRoughness": {},
          "topographyBathymetry": {},
          "perimeter_km": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": [
                "number",
                "null"
              ]
            }
          }
        }
      },
      "description": "Environmental context of the facility as dated historical state objects."
    },
    "historicalProgramAffiliation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date"
        ],
        "additionalProperties": true,
        "allOf": [
          {
            "$ref": "#/$defs/historicalObjectBase"
          }
        ],
        "properties": {
          "date": {
            "$ref": "#/$defs/dateOrOpen"
          },
          "programAffiliation": {
            "type": [
              "array",
              "string",
              "object",
              "null"
            ]
          },
          "programSpecificFacilityId": {
            "type": [
              "array",
              "string",
              "object",
              "null"
            ]
          },
          "reportingStatus": {
            "$ref": "#/$defs/codeValue"
          }
        }
      }
    },
    "historicalTerritory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date",
          "territory"
        ],
        "additionalProperties": true,
        "allOf": [
          {
            "$ref": "#/$defs/historicalObjectBase"
          }
        ],
        "properties": {
          "date": {
            "$ref": "#/$defs/dateOrOpen"
          },
          "territory": {
            "$ref": "#/$defs/codeValue"
          }
        }
      }
    },
    "instrument": {
      "type": "object",
      "required": [
        "id"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^instrument:"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "manufacturer": {
          "description": "Manufacturer of the equipment or instrument."
        },
        "model": {},
        "serialNumber": {
          "type": "string"
        },
        "observedProperty": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              }
            ]
          }
        },
        "observedGeometry": {
          "type": "string"
        },
        "verticalRange": {
          "type": "object",
          "required": [
            "min",
            "max"
          ],
          "additionalProperties": true,
          "properties": {
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            }
          }
        }
      }
    },
    "observation": {
      "type": "object",
      "required": [
        "id"
      ],
      "additionalProperties": true,
      "allOf": [
        {
          "not": {
            "required": [
              "deployments"
            ]
          }
        },
        {
          "not": {
            "required": [
              "reporting"
            ]
          }
        },
        {
          "not": {
            "required": [
              "domain"
            ]
          }
        },
        {
          "not": {
            "required": [
              "domainName"
            ]
          }
        },
        {
          "not": {
            "required": [
              "observedDomain"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalDataPolicy"
            ]
          }
        },
        {
          "not": {
            "required": [
              "programAffiliation"
            ]
          }
        },
        {
          "not": {
            "required": [
              "observedVariable"
            ]
          }
        },
        {
          "not": {
            "required": [
              "localReferenceSurface"
            ]
          }
        },
        {
          "not": {
            "required": [
              "observedGeometryType"
            ]
          }
        },
        {
          "not": {
            "required": [
              "description"
            ]
          }
        }
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^observations?:"
        },
        "title": {
          "type": "string"
        },
        "time": {
          "type": [
            "object",
            "null"
          ]
        },
        "applicationArea": {
          "type": [
            "array",
            "string",
            "object",
            "null"
          ]
        },
        "observedProperty": {},
        "observedGeometry": {},
        "observedFeature": {
          "$ref": "#/$defs/observedFeature"
        },
        "contacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contact"
          }
        },
        "sourceOfObservation": {
          "$ref": "#/$defs/codeValue"
        },
        "referenceSurface": {
          "$ref": "#/$defs/codeValue"
        },
        "representativeness": {},
        "verticalDistanceFromReferenceSurface": {
          "$ref": "#/$defs/quantity"
        },
        "historicalOfficialStatus": {
          "$ref": "#/$defs/historicalOfficialStatus"
        },
        "observingSchedules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scheduleReference"
          }
        },
        "historicalDeployments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/historicalDeployment"
          }
        },
        "historicalReporting": {
          "$ref": "#/$defs/historicalReporting"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "programAffiliations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/codeValue"
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "deprecated": true,
      "additionalProperties": false,
      "description": "Deprecated pre-v0.2.2 wrapper. Kept only for transition tests; use properties.historicalEnvironment instead.",
      "properties": {
        "temporalPopulation": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "topographyBathymetry": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "reporting": {
      "type": "object",
      "required": [
        "id"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^reporting:"
        },
        "internationalExchange": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "temporalReportingInterval": {
          "type": [
            "string",
            "null"
          ]
        },
        "temporalAggregate": {
          "type": [
            "string",
            "null"
          ]
        },
        "aggregation": {},
        "dataFormat": {},
        "dataPolicy": {},
        "levelOfData": {
          "$ref": "#/$defs/codeValue"
        },
        "numberOfObservationsInReportingInterval": {
          "type": [
            "integer",
            "number",
            "string",
            "null"
          ]
        },
        "referenceDatum": {},
        "referenceTimeSource": {},
        "timeliness": {},
        "timeStampMeaning": {}
      },
      "allOf": [
        {
          "not": {
            "required": [
              "date"
            ]
          }
        },
        {
          "not": {
            "required": [
              "uom"
            ]
          }
        },
        {
          "not": {
            "required": [
              "links"
            ]
          }
        }
      ]
    },
    "deployment": {
      "type": "object",
      "required": [
        "id"
      ],
      "additionalProperties": true,
      "description": "Reusable deployment / instrument-instance definition. Dated observation-specific deployment state is represented by historicalDeployment objects.",
      "allOf": [
        {
          "not": {
            "required": [
              "temporalSerialNumber"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalOfficialStatus"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalInstrumentOperatingStatus"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalObservingSchedule"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalGeometry"
            ]
          }
        },
        {
          "not": {
            "required": [
              "officialStatus"
            ]
          }
        },
        {
          "not": {
            "required": [
              "operatingStatus"
            ]
          }
        },
        {
          "not": {
            "required": [
              "geometry"
            ]
          }
        }
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^deployment:"
        },
        "instrument": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^instrument:"
            },
            {
              "type": "null"
            }
          ],
          "description": "Reference to the reusable instrument record for this deployed instrument instance."
        },
        "serialNumber": {
          "type": [
            "string",
            "null"
          ]
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        }
      }
    }
  }
}
