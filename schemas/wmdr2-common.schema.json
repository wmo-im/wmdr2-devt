{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wmo-im.github.io/wmdr2-devt/schemas/wmdr2-common.schema.json",
  "title": "WMDR2 common schema definitions",
  "type": "object",
  "$defs": {
    "dateOrOpen": {
      "type": "string",
      "description": "ISO date or '..' for open/unknown.",
      "anyOf": [
        {
          "const": ".."
        },
        {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      ]
    },
    "codeValue": {
      "description": "Compact codelist value, URI, number, structured value, or null.",
      "type": [
        "string",
        "number",
        "integer",
        "object",
        "array",
        "boolean",
        "null"
      ]
    },
    "quantity": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "value"
      ],
      "properties": {
        "value": {
          "type": [
            "number",
            "integer",
            "string"
          ]
        },
        "uom": {
          "$ref": "#/$defs/codeValue"
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "href"
      ],
      "properties": {
        "href": {
          "type": "string"
        },
        "rel": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "identifier": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "organization": {
          "type": "string"
        },
        "position": {
          "type": "string"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "emails": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "phones": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "addresses": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        }
      }
    },
    "pointGeometry": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "Point"
        },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "items": {
            "type": "number"
          }
        }
      },
      "additionalProperties": true
    },
    "temporalGeometry": {
      "type": "object",
      "description": "Trajectory-style exception that intentionally uses aligned coordinates/dates arrays.",
      "required": [
        "type",
        "coordinates",
        "dates"
      ],
      "properties": {
        "type": {
          "const": "MovingPoint"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "type": "array"
          }
        },
        "dates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dateOrOpen"
          }
        },
        "methods": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 0,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "additionalProperties": true
    },
    "observedFeature": {
      "type": "object",
      "required": [
        "domain"
      ],
      "additionalProperties": true,
      "properties": {
        "domain": {
          "$ref": "#/$defs/codeValue"
        },
        "domainFeature": {
          "type": [
            "string",
            "object",
            "null"
          ]
        },
        "featureName": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "allOf": [
        {
          "not": {
            "required": [
              "domainName"
            ]
          }
        }
      ]
    },
    "historicalObjectBase": {
      "type": "object",
      "required": [
        "date"
      ],
      "properties": {
        "date": {
          "$ref": "#/$defs/dateOrOpen"
        }
      },
      "additionalProperties": true
    },
    "historicalDeployment": {
      "type": "object",
      "required": [
        "date"
      ],
      "additionalProperties": true,
      "allOf": [
        {
          "$ref": "#/$defs/historicalObjectBase"
        },
        {
          "not": {
            "required": [
              "dates"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalSerialNumber"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalOfficialStatus"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalInstrumentOperatingStatus"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalObservingSchedule"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalGeometry"
            ]
          }
        },
        {
          "not": {
            "required": [
              "observingSchedule"
            ]
          }
        },
        {
          "not": {
            "required": [
              "sourceOfObservation"
            ]
          }
        },
        {
          "not": {
            "required": [
              "referenceSurface"
            ]
          }
        },
        {
          "not": {
            "required": [
              "verticalDistanceFromReferenceSurface"
            ]
          }
        },
        {
          "not": {
            "required": [
              "officialStatus"
            ]
          }
        },
        {
          "not": {
            "required": [
              "serialNumbers"
            ]
          }
        },
        {
          "not": {
            "required": [
              "instrument"
            ]
          }
        },
        {
          "not": {
            "required": [
              "serialNumber"
            ]
          }
        }
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^historicalDeployment:"
        },
        "date": {
          "$ref": "#/$defs/dateOrOpen"
        },
        "operatingStatus": {
          "$ref": "#/$defs/codeValue"
        },
        "exposure": {},
        "geometry": {
          "$ref": "#/$defs/pointGeometry"
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "deployment": {
          "type": "string",
          "pattern": "^deployment:",
          "description": "Reference to the reusable deployment / instrument instance used for this dated observation state."
        }
      }
    },
    "reportingEntry": {
      "type": "object",
      "required": [
        "date"
      ],
      "additionalProperties": true,
      "allOf": [
        {
          "$ref": "#/$defs/historicalObjectBase"
        },
        {
          "not": {
            "required": [
              "internationalExchange"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalReportingInterval"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalAggregate"
            ]
          }
        },
        {
          "not": {
            "required": [
              "aggregation"
            ]
          }
        },
        {
          "not": {
            "required": [
              "dataFormat"
            ]
          }
        },
        {
          "not": {
            "required": [
              "dataPolicy"
            ]
          }
        },
        {
          "not": {
            "required": [
              "levelOfData"
            ]
          }
        },
        {
          "not": {
            "required": [
              "numberOfObservationsInReportingInterval"
            ]
          }
        },
        {
          "not": {
            "required": [
              "referenceDatum"
            ]
          }
        },
        {
          "not": {
            "required": [
              "referenceTimeSource"
            ]
          }
        },
        {
          "not": {
            "required": [
              "timeliness"
            ]
          }
        },
        {
          "not": {
            "required": [
              "timeStampMeaning"
            ]
          }
        }
      ],
      "properties": {
        "date": {
          "$ref": "#/$defs/dateOrOpen"
        },
        "reporting": {
          "type": "string",
          "pattern": "^reporting:"
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "uom": {
          "$ref": "#/$defs/codeValue"
        }
      }
    },
    "reporting": {
      "type": "object",
      "required": [
        "id"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^reporting:"
        },
        "contact": {},
        "dataFormat": {},
        "dataPolicy": {},
        "internationalExchange": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "levelOfData": {
          "$ref": "#/$defs/codeValue"
        },
        "temporalReportingInterval": {
          "type": [
            "string",
            "null"
          ]
        },
        "temporalAggregate": {
          "type": [
            "string",
            "null"
          ]
        },
        "aggregation": {},
        "referenceDatum": {},
        "referenceTimeSource": {},
        "timeliness": {},
        "timeStampMeaning": {},
        "numberOfObservationsInReportingInterval": {}
      },
      "allOf": [
        {
          "not": {
            "required": [
              "date"
            ]
          }
        },
        {
          "not": {
            "required": [
              "uom"
            ]
          }
        },
        {
          "not": {
            "required": [
              "links"
            ]
          }
        }
      ]
    },
    "officialStatus": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date",
          "officialStatus"
        ],
        "additionalProperties": true,
        "allOf": [
          {
            "$ref": "#/$defs/historicalObjectBase"
          }
        ],
        "properties": {
          "date": {
            "$ref": "#/$defs/dateOrOpen"
          },
          "officialStatus": {
            "$ref": "#/$defs/codeValue"
          }
        }
      }
    },
    "scheduleReference": {
      "type": "object",
      "required": [
        "date",
        "schedule"
      ],
      "additionalProperties": true,
      "properties": {
        "date": {
          "$ref": "#/$defs/dateOrOpen"
        },
        "schedule": {
          "type": "string",
          "pattern": "^schedule_"
        }
      }
    },
    "schedule": {
      "type": "object",
      "required": [
        "@type",
        "uid"
      ],
      "additionalProperties": true,
      "properties": {
        "@type": {
          "type": "string"
        },
        "uid": {
          "type": "string",
          "pattern": "^schedule_"
        },
        "start": {
          "type": "string"
        },
        "timeZone": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "recurrenceRules": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "wmi.int:samplingFrequency": {
          "type": [
            "string",
            "null"
          ]
        },
        "wmo.int:aggregationInterval": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "allOf": [
        {
          "not": {
            "required": [
              "wmo.int:aggregation"
            ]
          }
        },
        {
          "not": {
            "required": [
              "diurnalBaseTime"
            ]
          }
        }
      ]
    },
    "environment": {
      "type": "array",
      "description": "Environmental context of the facility as dated Environment objects.",
      "items": {
        "type": "object",
        "required": [
          "date"
        ],
        "additionalProperties": true,
        "properties": {
          "date": {
            "$ref": "#/$defs/dateOrOpen"
          },
          "climateZone": {},
          "population": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": [
                "number",
                "null"
              ]
            }
          },
          "perimeter_km": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": [
                "number",
                "null"
              ]
            }
          },
          "surfaceCover": {},
          "surfaceRoughness": {},
          "topographyBathymetry": {}
        },
        "allOf": [
          {
            "not": {
              "required": [
                "temporalPopulation"
              ]
            }
          },
          {
            "not": {
              "required": [
                "topographyBathymetryTimeline"
              ]
            }
          },
          {
            "not": {
              "required": [
                "temporalPopulationDensities"
              ]
            }
          },
          {
            "not": {
              "required": [
                "temporalTopographyBathymetry"
              ]
            }
          }
        ]
      }
    },
    "programAffiliation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date"
        ],
        "additionalProperties": true,
        "allOf": [
          {
            "$ref": "#/$defs/historicalObjectBase"
          }
        ],
        "properties": {
          "date": {
            "$ref": "#/$defs/dateOrOpen"
          },
          "programAffiliation": {
            "type": [
              "array",
              "string",
              "object",
              "null"
            ]
          },
          "programSpecificFacilityId": {
            "type": [
              "array",
              "string",
              "object",
              "null"
            ]
          },
          "reportingStatus": {
            "$ref": "#/$defs/codeValue"
          }
        }
      }
    },
    "territory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "date",
          "territory"
        ],
        "additionalProperties": true,
        "allOf": [
          {
            "$ref": "#/$defs/historicalObjectBase"
          }
        ],
        "properties": {
          "date": {
            "$ref": "#/$defs/dateOrOpen"
          },
          "territory": {
            "$ref": "#/$defs/codeValue"
          }
        }
      }
    },
    "instrument": {
      "type": "object",
      "required": [
        "id"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^instrument:"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "manufacturer": {
          "description": "Manufacturer of the equipment or instrument."
        },
        "model": {},
        "serialNumber": {
          "type": "string"
        },
        "observedProperty": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "string"
              }
            ]
          }
        },
        "observedGeometry": {
          "type": "string"
        },
        "verticalRange": {
          "type": "object",
          "required": [
            "min",
            "max"
          ],
          "additionalProperties": true,
          "properties": {
            "min": {
              "type": "number"
            },
            "max": {
              "type": "number"
            }
          }
        },
        "observingMethods": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observingMethodValue"
          },
          "description": "Optional observing-method capabilities of this instrument catalogue entry. These values are not the authoritative dated history of an observation series."
        }
      },
      "description": "Instrument catalogue metadata. Deployed instrument instances are represented by deployment records. Optional observingMethods list instrument capabilities when known; the dated method history belongs to ObservationSeries."
    },
    "observation": {
      "type": "object",
      "required": [
        "id"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^observationSeries:"
        },
        "title": {
          "type": "string"
        },
        "time": {
          "type": [
            "object",
            "null"
          ]
        },
        "applicationArea": {
          "type": [
            "array",
            "string",
            "object",
            "null"
          ]
        },
        "observedProperty": {},
        "observedGeometry": {},
        "observedFeature": {
          "$ref": "#/$defs/observedFeature"
        },
        "contacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contact"
          }
        },
        "sourceOfObservation": {
          "$ref": "#/$defs/codeValue"
        },
        "referenceSurface": {
          "$ref": "#/$defs/codeValue"
        },
        "representativeness": {},
        "verticalDistanceFromReferenceSurface": {
          "$ref": "#/$defs/quantity"
        },
        "officialStatus": {
          "$ref": "#/$defs/officialStatus"
        },
        "deployments": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^deployment:"
          }
        },
        "reporting": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reportingProcedure"
          }
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "programAffiliation": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/codeValue"
          }
        },
        "observingProcedures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observingProcedure"
          }
        }
      },
      "allOf": [
        {
          "not": {
            "required": [
              "historicalDeployments"
            ]
          }
        },
        {
          "not": {
            "required": [
              "historicalReporting"
            ]
          }
        },
        {
          "not": {
            "required": [
              "historicalOfficialStatus"
            ]
          }
        },
        {
          "not": {
            "required": [
              "domain"
            ]
          }
        },
        {
          "not": {
            "required": [
              "domainName"
            ]
          }
        },
        {
          "not": {
            "required": [
              "observedDomain"
            ]
          }
        },
        {
          "not": {
            "required": [
              "programAffiliations"
            ]
          }
        },
        {
          "not": {
            "required": [
              "observedVariable"
            ]
          }
        },
        {
          "not": {
            "required": [
              "localReferenceSurface"
            ]
          }
        },
        {
          "not": {
            "required": [
              "observedGeometryType"
            ]
          }
        },
        {
          "not": {
            "required": [
              "description"
            ]
          }
        },
        {
          "not": {
            "required": [
              "observingSchedules"
            ]
          }
        },
        {
          "not": {
            "required": [
              "historicalObservingProcedure"
            ]
          }
        }
      ]
    },
    "deployment": {
      "type": "object",
      "required": [
        "id",
        "date"
      ],
      "additionalProperties": true,
      "description": "Dated Deployment object. It represents a deployed instrument instance/state and can be referenced by one or more ObservationSeries.",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^deployment:"
        },
        "date": {
          "$ref": "#/$defs/dateOrOpen"
        },
        "instrument": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^instrument:"
            },
            {
              "type": "null"
            }
          ]
        },
        "serialNumber": {
          "type": [
            "string",
            "null"
          ]
        },
        "operatingStatus": {
          "$ref": "#/$defs/codeValue"
        },
        "exposure": {},
        "geometry": {
          "$ref": "#/$defs/pointGeometry"
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        }
      },
      "allOf": [
        {
          "not": {
            "required": [
              "temporalSerialNumber"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalOfficialStatus"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalGeometry"
            ]
          }
        },
        {
          "not": {
            "required": [
              "serialNumbers"
            ]
          }
        }
      ]
    },
    "datedObjectBase": {
      "type": "object",
      "required": [
        "date"
      ],
      "properties": {
        "date": {
          "$ref": "#/$defs/dateOrOpen"
        }
      },
      "additionalProperties": true
    },
    "reportingProcedure": {
      "type": "object",
      "required": [
        "date",
        "strategy",
        "reporting"
      ],
      "additionalProperties": true,
      "description": "Dated ReportingProcedure object linking an ObservationSeries to a reusable reporting definition.",
      "properties": {
        "date": {
          "$ref": "#/$defs/dateOrOpen"
        },
        "reporting": {
          "type": "string",
          "pattern": "^reporting:"
        },
        "strategy": {
          "$ref": "#/$defs/codeValue"
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "uom": {
          "$ref": "#/$defs/codeValue"
        }
      },
      "allOf": [
        {
          "not": {
            "required": [
              "internationalExchange"
            ]
          }
        },
        {
          "not": {
            "required": [
              "temporalAggregate"
            ]
          }
        },
        {
          "not": {
            "required": [
              "dataPolicy"
            ]
          }
        },
        {
          "not": {
            "required": [
              "levelOfData"
            ]
          }
        },
        {
          "not": {
            "required": [
              "timeliness"
            ]
          }
        }
      ]
    },
    "observationSeries": {
      "type": "object",
      "required": [
        "id"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^observationSeries:"
        },
        "title": {
          "type": "string"
        },
        "time": {
          "type": [
            "object",
            "null"
          ]
        },
        "applicationArea": {
          "type": [
            "array",
            "string",
            "object",
            "null"
          ]
        },
        "observedProperty": {},
        "observedGeometry": {},
        "observedFeature": {
          "$ref": "#/$defs/observedFeature"
        },
        "contacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contact"
          }
        },
        "sourceOfObservation": {
          "$ref": "#/$defs/codeValue"
        },
        "referenceSurface": {
          "$ref": "#/$defs/codeValue"
        },
        "representativeness": {},
        "verticalDistanceFromReferenceSurface": {
          "$ref": "#/$defs/quantity"
        },
        "officialStatus": {
          "$ref": "#/$defs/officialStatus"
        },
        "deployments": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^deployment:"
          }
        },
        "reporting": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reportingProcedure"
          }
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "programAffiliation": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/codeValue"
          }
        },
        "observingProcedures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observingProcedure"
          }
        },
        "observingMethods": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observingMethod"
          },
          "description": "Dated observing-method history associated with this observation series."
        }
      },
      "allOf": [
        {
          "not": {
            "required": [
              "historicalDeployments"
            ]
          }
        },
        {
          "not": {
            "required": [
              "historicalReporting"
            ]
          }
        },
        {
          "not": {
            "required": [
              "historicalOfficialStatus"
            ]
          }
        },
        {
          "not": {
            "required": [
              "domain"
            ]
          }
        },
        {
          "not": {
            "required": [
              "domainName"
            ]
          }
        },
        {
          "not": {
            "required": [
              "observedDomain"
            ]
          }
        },
        {
          "not": {
            "required": [
              "programAffiliations"
            ]
          }
        },
        {
          "not": {
            "required": [
              "observedVariable"
            ]
          }
        },
        {
          "not": {
            "required": [
              "localReferenceSurface"
            ]
          }
        },
        {
          "not": {
            "required": [
              "observedGeometryType"
            ]
          }
        },
        {
          "not": {
            "required": [
              "description"
            ]
          }
        },
        {
          "not": {
            "required": [
              "observingSchedules"
            ]
          }
        },
        {
          "not": {
            "required": [
              "historicalObservingProcedure"
            ]
          }
        }
      ]
    },
    "observingProcedure": {
      "type": "object",
      "required": [
        "date",
        "strategy",
        "observingSchedules"
      ],
      "additionalProperties": true,
      "description": "Dated ObservingProcedure object linking an ObservationSeries to one or more reusable observing schedules.",
      "properties": {
        "date": {
          "$ref": "#/$defs/dateOrOpen"
        },
        "strategy": {
          "$ref": "#/$defs/codeValue"
        },
        "observingSchedules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^schedule_"
          }
        }
      },
      "allOf": [
        {
          "not": {
            "required": [
              "observingSchedule"
            ]
          }
        },
        {
          "not": {
            "required": [
              "schedule"
            ]
          }
        }
      ]
    },
    "procedure": {
      "type": "object",
      "required": [
        "id"
      ],
      "additionalProperties": true,
      "description": "Reusable Procedure definition referenced by observation series where the source provides a stable observing procedure concept.",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^procedure:"
        }
      }
    },
    "nilReason": {
      "type": "object",
      "required": [
        "nilReason"
      ],
      "additionalProperties": false,
      "description": "Nil-reason object used when a mandatory WMDR2 value is unknown, missing, withheld, inapplicable, or otherwise not available from source metadata.",
      "properties": {
        "nilReason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "observingMethod": {
      "type": "object",
      "required": [
        "date",
        "observingMethod"
      ],
      "additionalProperties": true,
      "description": "Dated observing-method history entry for an ObservationSeries. In v0.2.4.2 the observingMethod value is mandatory; use a nilReason object when the method is not known.",
      "properties": {
        "date": {
          "$ref": "#/$defs/dateOrOpen"
        },
        "observingMethod": {
          "$ref": "#/$defs/observingMethodValue"
        }
      }
    },
    "observingMethodValue": {
      "description": "Mandatory observing-method value, or a nilReason object when unknown, missing, withheld, or otherwise unavailable.",
      "anyOf": [
        {
          "$ref": "#/$defs/codeValue"
        },
        {
          "$ref": "#/$defs/nilReason"
        }
      ]
    }
  }
}
