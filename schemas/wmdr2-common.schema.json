{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.wmo.int/wmdr/2.0/schemas/wmdr2-common.schema.json",
  "title": "WMDR2 core common JSON schema definitions",
  "type": "object",
  "$defs": {
    "uri": {
      "type": "string",
      "minLength": 1
    },
    "identifier": {
      "type": "string",
      "minLength": 1
    },
    "dateTimeOrOpen": {
      "type": "string",
      "minLength": 1,
      "description": "RFC 3339 date/time string or the OGC open-interval marker '..'. The converter may also preserve legacy date strings such as 2000-08-17Z during the transition."
    },
    "timeInterval": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "interval"
      ],
      "properties": {
        "interval": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "$ref": "#/$defs/dateTimeOrOpen"
          }
        },
        "resolution": {
          "type": "string"
        }
      }
    },
    "pointGeometry": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "type",
        "coordinates"
      ],
      "additionalProperties": true,
      "properties": {
        "type": {
          "const": "Point"
        },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "items": {
            "type": "number"
          }
        }
      }
    },
    "temporalGeometry": {
      "type": "object",
      "required": [
        "type",
        "coordinates",
        "datetimes"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "MovingPoint"
        },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 3,
            "items": {
              "type": "number"
            }
          }
        },
        "datetimes": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/dateTimeOrOpen"
          }
        }
      }
    },
    "externalId": {
      "type": "object",
      "required": [
        "scheme",
        "value"
      ],
      "additionalProperties": true,
      "properties": {
        "scheme": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "link": {
      "type": "object",
      "required": [
        "href",
        "rel"
      ],
      "additionalProperties": true,
      "properties": {
        "href": {
          "type": "string",
          "minLength": 1
        },
        "rel": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "identifier": {
          "$ref": "#/$defs/identifier"
        },
        "name": {
          "type": "string"
        },
        "position": {
          "type": "string"
        },
        "organization": {
          "type": "string"
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "emails": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "value"
            ],
            "additionalProperties": true,
            "properties": {
              "value": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "phones": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "value"
            ],
            "additionalProperties": true,
            "properties": {
              "value": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "addresses": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        }
      }
    },
    "simpleTemporalHistory": {
      "type": "object",
      "required": [
        "datetimes"
      ],
      "additionalProperties": true,
      "properties": {
        "datetimes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dateTimeOrOpen"
          }
        }
      }
    },
    "temporalTerritory": {
      "allOf": [
        {
          "$ref": "#/$defs/simpleTemporalHistory"
        },
        {
          "type": "object",
          "required": [
            "territory"
          ],
          "properties": {
            "territory": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/codeValue"
              }
            }
          }
        }
      ]
    },
    "temporalClimateZone": {
      "allOf": [
        {
          "$ref": "#/$defs/simpleTemporalHistory"
        },
        {
          "type": "object",
          "required": [
            "climateZone"
          ],
          "properties": {
            "climateZone": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/codeValue"
              }
            }
          }
        }
      ]
    },
    "temporalSurfaceCover": {
      "allOf": [
        {
          "$ref": "#/$defs/simpleTemporalHistory"
        },
        {
          "type": "object",
          "required": [
            "surfaceCover"
          ],
          "properties": {
            "surfaceCover": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/codeValue"
              }
            }
          }
        }
      ]
    },
    "reportingStatusTimeline": {
      "type": "object",
      "required": [
        "reportingStatus",
        "datetimes"
      ],
      "additionalProperties": true,
      "properties": {
        "reportingStatus": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/codeValue"
          }
        },
        "datetimes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dateTimeOrOpen"
          }
        }
      }
    },
    "programAffiliationTimeline": {
      "type": "object",
      "required": [
        "programAffiliation"
      ],
      "additionalProperties": true,
      "properties": {
        "programAffiliation": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/codeValue"
          }
        },
        "programSpecificFacilityId": {
          "type": "string"
        },
        "reportingStatus": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/codeValue"
          }
        },
        "datetimes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dateTimeOrOpen"
          }
        }
      }
    },
    "temporalProgramAffiliation": {
      "type": "object",
      "required": [
        "programAffiliation",
        "datetimes"
      ],
      "additionalProperties": false,
      "properties": {
        "programAffiliation": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/codeValue"
          }
        },
        "reportingStatus": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/codeValue"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "programSpecificFacilityId": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "datetimes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dateTimeOrOpen"
          }
        }
      }
    },
    "temporalObservingSchedule": {
      "type": "object",
      "additionalProperties": true,
      "not": {
        "required": [
          "id"
        ]
      },
      "properties": {
        "interval": {
          "type": "string"
        },
        "startMonth": {
          "type": [
            "integer",
            "number",
            "string"
          ]
        },
        "endMonth": {
          "type": [
            "integer",
            "number",
            "string"
          ]
        },
        "startWeekday": {
          "type": [
            "integer",
            "number",
            "string"
          ]
        },
        "endWeekday": {
          "type": [
            "integer",
            "number",
            "string"
          ]
        },
        "startHour": {
          "type": [
            "integer",
            "number",
            "string"
          ]
        },
        "endHour": {
          "type": [
            "integer",
            "number",
            "string"
          ]
        },
        "startMinute": {
          "type": [
            "integer",
            "number",
            "string"
          ]
        },
        "endMinute": {
          "type": [
            "integer",
            "number",
            "string"
          ]
        },
        "diurnalBaseTime": {
          "type": "string"
        }
      }
    },
    "reporting": {
      "type": "object",
      "additionalProperties": {
        "type": "array"
      },
      "allOf": [
        {
          "not": {
            "required": [
              "id"
            ]
          }
        },
        {
          "not": {
            "required": [
              "interval"
            ]
          }
        }
      ],
      "properties": {
        "internationalExchange": {
          "type": "array",
          "items": {
            "type": [
              "boolean",
              "null"
            ]
          }
        },
        "temporalReportingInterval": {
          "type": "array",
          "items": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "uom": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/codeValue"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "referenceDatum": {
          "type": "array",
          "items": {
            "type": [
              "object",
              "null"
            ]
          }
        }
      }
    },
    "temporalDataPolicy": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "dataPolicy": {
          "$ref": "#/$defs/codeValue"
        },
        "time": {
          "$ref": "#/$defs/timeInterval"
        }
      }
    },
    "observation": {
      "type": "object",
      "required": [
        "id",
        "observedVariable"
      ],
      "additionalProperties": true,
      "allOf": [
        {
          "not": {
            "required": [
              "themes"
            ]
          }
        },
        {
          "not": {
            "required": [
              "wmdr2"
            ]
          }
        },
        {
          "not": {
            "required": [
              "type"
            ]
          }
        },
        {
          "not": {
            "required": [
              "internationalReportingSchedule"
            ]
          }
        }
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^observation:"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "time": {
          "$ref": "#/$defs/nullableTimeInterval"
        },
        "observedVariable": {
          "$ref": "#/$defs/codeValue"
        },
        "observedGeometryType": {
          "$ref": "#/$defs/codeValue"
        },
        "observedDomain": {
          "$ref": "#/$defs/codeValue"
        },
        "programAffiliation": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/programAffiliationTimeline"
          }
        },
        "contacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contact"
          }
        },
        "temporalObservingSchedule": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/temporalObservingSchedule"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "reporting": {
          "$ref": "#/$defs/reporting"
        },
        "temporalDataPolicy": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/temporalDataPolicy"
          }
        },
        "deployments": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^deployment:"
          }
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        }
      }
    },
    "deployment": {
      "type": "object",
      "required": [
        "id"
      ],
      "additionalProperties": true,
      "allOf": [
        {
          "not": {
            "required": [
              "themes"
            ]
          }
        },
        {
          "not": {
            "required": [
              "wmdr2"
            ]
          }
        },
        {
          "not": {
            "required": [
              "type"
            ]
          }
        },
        {
          "not": {
            "required": [
              "title"
            ]
          }
        },
        {
          "not": {
            "required": [
              "manufacturer"
            ]
          }
        },
        {
          "not": {
            "required": [
              "model"
            ]
          }
        },
        {
          "not": {
            "required": [
              "serialNumber"
            ]
          }
        }
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^deployment:"
        },
        "time": {
          "$ref": "#/$defs/nullableTimeInterval"
        },
        "description": {
          "type": "string"
        },
        "sourceOfObservation": {
          "$ref": "#/$defs/codeValue"
        },
        "observingMethod": {
          "$ref": "#/$defs/codeValue"
        },
        "exposure": {},
        "representativeness": {},
        "localReferenceSurface": {
          "$ref": "#/$defs/codeValue"
        },
        "instrumentOperatingStatus": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "contacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/contact"
          }
        },
        "temporalObservingSchedule": {
          "anyOf": [
            {
              "type": "array",
              "items": {
                "$ref": "#/$defs/temporalObservingSchedule"
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "links": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "instrument": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^instrument:"
          }
        },
        "serialNumbers": {
          "type": "object",
          "required": [
            "serialNumber",
            "datetimes"
          ],
          "additionalProperties": false,
          "properties": {
            "serialNumber": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "datetimes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/dateTimeOrOpen"
              }
            }
          }
        }
      }
    },
    "codeValue": {
      "description": "Compact code-list value. The applicable code list is defined by the property context and checked by a WMDR2 validator.",
      "type": [
        "string",
        "integer"
      ]
    },
    "nullableTimeInterval": {
      "anyOf": [
        {
          "$ref": "#/$defs/timeInterval"
        },
        {
          "type": "null"
        }
      ]
    },
    "instrument": {
      "type": "object",
      "required": [
        "id"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^instrument:"
        },
        "manufacturer": {
          "type": "string"
        },
        "model": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "not": {
            "required": [
              "serialNumbers"
            ]
          }
        }
      ]
    }
  }
}
