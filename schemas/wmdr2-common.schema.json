{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wmo.int/wmdr2/schemas/wmdr2-common.schema.json",
  "title": "WMDR2 v0.3.1 common definitions",
  "type": "object",
  "$defs": {
    "nilReason": {
      "type": "object",
      "required": [
        "nilReason"
      ],
      "properties": {
        "nilReason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "codeOrNilReason": {
      "oneOf": [
        {
          "type": [
            "string",
            "integer",
            "number",
            "boolean"
          ]
        },
        {
          "$ref": "#/$defs/nilReason"
        }
      ]
    },
    "quantity": {
      "type": "object",
      "required": [
        "value"
      ],
      "properties": {
        "value": {
          "type": [
            "number",
            "integer",
            "string"
          ]
        },
        "uom": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "pointGeometry": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "const": "Point"
        },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "maxItems": 3,
          "items": {
            "type": "number"
          }
        }
      },
      "additionalProperties": true
    },
    "temporalGeometry": {
      "type": "object",
      "required": [
        "type",
        "coordinates",
        "dates"
      ],
      "properties": {
        "type": {
          "const": "MovingPoint"
        },
        "coordinates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 3,
            "items": {
              "type": "number"
            }
          }
        },
        "dates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "methods": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      },
      "additionalProperties": false
    },
    "time": {
      "type": "object",
      "properties": {
        "interval": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "string"
          }
        },
        "resolution": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "jscalendarRecurrenceRule": {
      "type": "object",
      "required": [
        "@type",
        "frequency"
      ],
      "properties": {
        "@type": {
          "const": "RecurrenceRule"
        },
        "frequency": {
          "type": "string"
        },
        "interval": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    "schedule": {
      "type": "object",
      "required": [
        "@type",
        "start",
        "uid"
      ],
      "properties": {
        "@type": {
          "type": "string"
        },
        "start": {
          "type": "string"
        },
        "uid": {
          "type": "string",
          "minLength": 1
        },
        "timeZone": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "recurrenceRules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jscalendarRecurrenceRule"
          }
        },
        "wmo.int:aggregationInterval": {
          "type": "string"
        },
        "wmo.int:samplingFrequency": {
          "type": "string"
        },
        "wmo.int:diurnalBaseTime": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "observingLocation": {
      "type": "object",
      "properties": {
        "geometry": {
          "$ref": "#/$defs/pointGeometry"
        },
        "referenceSurface": {
          "type": [
            "string",
            "integer"
          ]
        },
        "relativeLocation": {
          "type": "string"
        },
        "verticalDistanceFromReferenceSurface": {
          "$ref": "#/$defs/quantity"
        }
      },
      "additionalProperties": true
    },
    "observingConfiguration": {
      "type": "object",
      "required": [
        "validFrom",
        "observingMethod",
        "operatingStatus",
        "sourceOfObservation"
      ],
      "properties": {
        "validFrom": {
          "$ref": "#/$defs/knownValidFrom"
        },
        "observingLocation": {
          "$ref": "#/$defs/observingLocation"
        },
        "deployment": false,
        "observingMethod": {
          "$ref": "#/$defs/codeOrNilReason"
        },
        "operatingStatus": {
          "$ref": "#/$defs/codeOrNilReason"
        },
        "sourceOfObservation": {
          "$ref": "#/$defs/codeOrNilReason"
        },
        "exposure": {
          "type": [
            "string",
            "integer",
            "number"
          ]
        }
      },
      "additionalProperties": true
    },
    "observingProcedure": {
      "type": "object",
      "required": [
        "validFrom",
        "strategy",
        "observingSchedules"
      ],
      "properties": {
        "validFrom": {
          "$ref": "#/$defs/knownValidFrom"
        },
        "strategy": {
          "$ref": "#/$defs/codeOrNilReason"
        },
        "observingSchedules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "reportingProcedure": {
      "type": "object",
      "properties": {
        "validFrom": false,
        "internationalExchange": {
          "type": "boolean"
        },
        "uom": {
          "type": [
            "string",
            "integer"
          ]
        },
        "temporalReportingInterval": {
          "type": "string"
        },
        "spatialReportingInterval": {
          "type": [
            "string",
            "integer",
            "number"
          ]
        },
        "timeliness": {
          "type": "string"
        },
        "dataPolicy": {
          "type": [
            "string",
            "integer"
          ]
        },
        "levelOfData": {
          "type": [
            "string",
            "integer"
          ]
        },
        "numberOfObservationsInReportingInterval": {
          "type": [
            "integer",
            "number",
            "string"
          ]
        },
        "referenceDatum": {
          "type": [
            "string",
            "integer"
          ]
        },
        "referenceTimeSource": {
          "type": [
            "string",
            "integer"
          ]
        },
        "strategy": {
          "$ref": "#/$defs/codeOrNilReason"
        },
        "timeStampMeaning": {
          "type": [
            "string",
            "integer"
          ]
        },
        "reportingSchedules": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "$ref": "#/$defs/schedule"
              }
            ]
          }
        },
        "links": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "observedFeature": {
      "type": "object",
      "properties": {
        "domain": {
          "type": [
            "string",
            "integer"
          ]
        },
        "domainFeature": {
          "type": "string"
        },
        "featureName": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "topographyBathymetry": {
      "type": "object",
      "properties": {
        "localTopography": {
          "type": [
            "string",
            "integer",
            "number",
            "boolean"
          ]
        },
        "relativeElevation": {
          "type": [
            "string",
            "integer",
            "number",
            "boolean"
          ]
        },
        "topographicContext": {
          "type": [
            "string",
            "integer",
            "number",
            "boolean"
          ]
        },
        "altitudeOrDepth": {
          "type": [
            "string",
            "integer",
            "number",
            "boolean"
          ]
        }
      },
      "additionalProperties": false
    },
    "environmentItem": {
      "type": "object",
      "properties": {
        "validFrom": {
          "type": "string",
          "minLength": 1
        },
        "date": {
          "type": "string",
          "minLength": 1
        },
        "climateZone": {
          "type": [
            "string",
            "integer"
          ]
        },
        "surfaceCover": {
          "type": [
            "string",
            "integer"
          ]
        },
        "surfaceClassification": {
          "type": [
            "string",
            "integer"
          ]
        },
        "surfaceRoughness": {
          "type": [
            "string",
            "integer"
          ]
        },
        "population": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": [
              "number",
              "integer",
              "null"
            ]
          }
        },
        "perimeter_km": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": [
              "number",
              "integer",
              "null"
            ]
          }
        },
        "topographyBathymetry": {
          "$ref": "#/$defs/topographyBathymetry"
        }
      },
      "additionalProperties": false,
      "not": {
        "anyOf": [
          {
            "required": [
              "temporalPopulationDensities"
            ]
          },
          {
            "required": [
              "temporalLocalTopography"
            ]
          },
          {
            "required": [
              "temporalRelativeElevation"
            ]
          },
          {
            "required": [
              "temporalTopographicContext"
            ]
          },
          {
            "required": [
              "temporalAltitudeOrDepth"
            ]
          },
          {
            "required": [
              "temporalTopographyBathymetry"
            ]
          }
        ]
      }
    },
    "environment": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/environmentItem"
      }
    },
    "programAffiliation": {
      "type": "object",
      "properties": {
        "validFrom": {
          "type": "string"
        },
        "program": {
          "oneOf": [
            {
              "type": [
                "string",
                "integer"
              ]
            },
            {
              "type": "array",
              "items": {
                "type": [
                  "string",
                  "integer"
                ]
              }
            }
          ]
        },
        "programSpecificFacilityId": {
          "type": "string"
        },
        "programSpecificFacilityTitle": {
          "type": "string"
        },
        "reportingStatus": {
          "type": [
            "string",
            "integer"
          ]
        }
      },
      "additionalProperties": true
    },
    "territory": {
      "type": "object",
      "properties": {
        "validFrom": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "territory": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "deployment": {
      "type": "object",
      "properties": {
        "geometry": {
          "$ref": "#/$defs/pointGeometry"
        },
        "referenceSurface": {
          "type": [
            "string",
            "integer"
          ]
        },
        "relativeLocation": {
          "type": "string"
        },
        "verticalDistanceFromReferenceSurface": {
          "$ref": "#/$defs/quantity"
        }
      },
      "additionalProperties": true
    },
    "reporting": {
      "type": "object",
      "properties": {
        "validFrom": false,
        "internationalExchange": {
          "type": "boolean"
        },
        "uom": {
          "type": [
            "string",
            "integer"
          ]
        },
        "temporalReportingInterval": {
          "type": "string"
        },
        "spatialReportingInterval": {
          "type": [
            "string",
            "integer",
            "number"
          ]
        },
        "timeliness": {
          "type": "string"
        },
        "dataPolicy": {
          "type": [
            "string",
            "integer"
          ]
        },
        "levelOfData": {
          "type": [
            "string",
            "integer"
          ]
        },
        "numberOfObservationsInReportingInterval": {
          "type": [
            "integer",
            "number",
            "string"
          ]
        },
        "referenceDatum": {
          "type": [
            "string",
            "integer"
          ]
        },
        "referenceTimeSource": {
          "type": [
            "string",
            "integer"
          ]
        },
        "strategy": {
          "$ref": "#/$defs/codeOrNilReason"
        },
        "timeStampMeaning": {
          "type": [
            "string",
            "integer"
          ]
        },
        "reportingSchedules": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "$ref": "#/$defs/schedule"
              }
            ]
          }
        },
        "links": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "officialStatus": {
      "type": "object",
      "properties": {
        "date": {
          "type": "string"
        },
        "officialStatus": {
          "type": [
            "string",
            "integer"
          ]
        }
      },
      "additionalProperties": true
    },
    "observationSeries": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "time": {
          "$ref": "#/$defs/time"
        },
        "observedProperty": {
          "type": [
            "string",
            "integer",
            "number"
          ]
        },
        "observedGeometry": {
          "type": [
            "string",
            "integer",
            "number"
          ]
        },
        "observedFeature": {
          "$ref": "#/$defs/observedFeature"
        },
        "observingConfigurations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observingConfiguration"
          }
        },
        "observingProcedures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observingProcedure"
          }
        },
        "officialStatus": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/officialStatus"
          }
        },
        "keywords": {
          "type": "array"
        },
        "links": {
          "type": "array"
        },
        "deployments": false,
        "observedVariable": false,
        "observedDomain": false,
        "uid": {
          "type": "string"
        },
        "programAffiliations": {
          "type": "array"
        },
        "reportingProcedures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reportingProcedure"
          }
        }
      },
      "additionalProperties": true
    },
    "observation": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "time": {
          "$ref": "#/$defs/time"
        },
        "observedProperty": {
          "type": [
            "string",
            "integer",
            "number"
          ]
        },
        "observedGeometry": {
          "type": [
            "string",
            "integer",
            "number"
          ]
        },
        "observedFeature": {
          "$ref": "#/$defs/observedFeature"
        },
        "observingConfigurations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observingConfiguration"
          }
        },
        "observingProcedures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/observingProcedure"
          }
        },
        "officialStatus": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/officialStatus"
          }
        },
        "keywords": {
          "type": "array"
        },
        "links": {
          "type": "array"
        },
        "deployments": false,
        "observedVariable": false,
        "observedDomain": false,
        "uid": {
          "type": "string"
        },
        "programAffiliations": {
          "type": "array"
        },
        "reportingProcedures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/reportingProcedure"
          }
        }
      },
      "additionalProperties": true
    },
    "instrument": {
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        }
      },
      "additionalProperties": true,
      "required": [
        "uid"
      ]
    },
    "contact": {
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "knownValidFrom": {
      "type": "string",
      "minLength": 1,
      "not": {
        "const": ".."
      }
    }
  }
}
