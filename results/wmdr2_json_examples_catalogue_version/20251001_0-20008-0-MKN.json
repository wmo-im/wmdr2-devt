  "properties": {
    "type": "facility",
    "title": "Mt. Kenya",
    "created": "2025-10-01T00:00:00Z",
    "updated": "2025-10-01T00:00:00Z",
    "additionalTitles": [
      "Mount Kenya"
    ],
    "description": "The station is situated above Moses Camp on the northern upper slopes of Mt. Kenya in a wildlife preserve above the tree line and provides measurements of the tropical mid-troposphere as well as air from the lower humid boundary layer. Access is along Sirimon Route, a distance of 21km from the Nanyuki-Timau main road. The turn-off is about 16km from Nanyuki. A new settlement has been created in the former forest land after the turn-off. The asphalt / concrete road leads up to Old Moses camp, beyond which a rugged footpath leads to the station. The station itself consists of 2 cargo containers with expansions and sanitary facilities on site. One of the containers host the instrument racks.",
    "facilityType": "landFixed",
